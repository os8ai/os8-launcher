# Model weights (large files)
models/*/weights/

# Python virtual environments
serving/*/venv/
clients/*/venv/

# Install state markers — written by ./launcher install at runtime.
# Committing these would make a fresh clone falsely report the backend
# as installed (get_tool_status only checks for the file's presence).
serving/*/.installed
serving/*/.installing
clients/*/.installed
clients/*/.installing

# Cloned upstream repos (installed at setup time)
serving/*/repo/

# Downloaded binaries and shared libs
serving/*/bin/
serving/*/lib/
clients/*/bin/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Project venv
.venv/

# Environment
.env

# IDE
.vscode/
.idea/
.aider*

# Runtime logs from ./start
var/
