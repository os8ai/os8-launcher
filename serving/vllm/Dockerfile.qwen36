# Thin layer over vLLM cu130-nightly for Qwen3.6-35B-A3B.
#
# The model (published 2026-04-15) introduces the Qwen3_5MoeForConditionalGeneration
# architecture, qwen3 reasoning parser, and qwen3_next_mtp speculative method.
# These shipped in vLLM nightlies from mid-April 2026 onward.
#
# Before `docker build`, refresh the base so you get the newest nightly:
#   docker pull vllm/vllm-openai:cu130-nightly
#
# Transformers is upgraded to HEAD in case the model needs processor code that
# isn't yet in a tagged release — mirrors Dockerfile.gemma4's approach.
# Remove this image once a cu130-nightly ships stable support for this arch.
FROM vllm/vllm-openai:cu130-nightly
RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*
# pandas: the cu130-nightly from 2026-04-16 imports pandas unconditionally
# from vllm/_aiter_ops.py but doesn't ship it — vllm crashes at startup.
# Remove once upstream either makes pandas a hard dep or drops the import.
RUN pip install --no-cache-dir pandas
RUN pip install --no-cache-dir -U "git+https://github.com/huggingface/transformers.git"
