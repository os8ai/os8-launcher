#!/usr/bin/env python3
"""os8-launcher CLI entry point.

Uses the project's .venv if available, otherwise falls back to system Python.
"""

import os
import sys
from pathlib import Path

repo_root = Path(__file__).resolve().parent

# If we're not already in the project venv, re-exec with it
venv_python = repo_root / ".venv" / "bin" / "python3"
if venv_python.exists() and sys.prefix == sys.base_prefix:
    os.execv(str(venv_python), [str(venv_python), __file__] + sys.argv[1:])

sys.path.insert(0, str(repo_root))

from src.cli import main

main(repo_root)
